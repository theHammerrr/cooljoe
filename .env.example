# App database used by the backend itself for local state, draft jobs, analytics, and schema snapshots
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cooljoe_app?schema=public"

# Project database that the workspace explores and queries
# Prefer a read-only user here when possible
PROJECT_DATABASE_URL="postgresql://readonly:readonly_pass@localhost:5432/your_project_db?schema=public"

# Legacy fallback name, still supported by the API
# TARGET_DATABASE_URL="postgresql://readonly:readonly_pass@localhost:5432/your_project_db?schema=public"

# AI provider: openai or ollama
AI_PROVIDER="ollama"

# Model selection
AI_MODEL="llama3"
AI_EMBEDDING_MODEL="nomic-embed-text"

# OpenAI configuration
OPENAI_API_KEY=""

# Ollama configuration
OLLAMA_HOST="http://127.0.0.1:11434"

# Optional
PORT=3001
TABLE_ALLOWLIST=""
OPS_API_TOKEN=""
