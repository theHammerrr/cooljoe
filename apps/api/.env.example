# Application Configuration
PORT=3001

# Prisma Configuration (The DB Copilot's local state and vector storage)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public"

# Target Database Configuration (The READ-ONLY connection to the DB to be analyzed)
TARGET_DATABASE_URL="postgresql://readonly:readonly_pass@localhost:5432/target_db?schema=public"

# AI Provider Configuration
# Set to 'openai' or 'ollama' (defaults to ollama)
AI_PROVIDER="ollama"

# Set the models to use (defaults depend on provider)
# AI_MODEL="llama3" 
# AI_EMBEDDING_MODEL="nomic-embed-text"

# If using OpenAI:
OPENAI_API_KEY="sk-..."

# If using Ollama, defaults to http://127.0.0.1:11434 and llama3
# OLLAMA_HOST="http://127.0.0.1:11434"
