# Application Configuration
PORT=3001

# Prisma Configuration (The DB Copilot's local state and vector storage)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public"

# Project Database Configuration (the database this workspace will query)
# Use a read-only user if possible. PROJECT_DATABASE_URL is the preferred name.
PROJECT_DATABASE_URL="postgresql://readonly:readonly_pass@localhost:5432/target_db?schema=public"
# Legacy name still supported for backward compatibility:
# TARGET_DATABASE_URL="postgresql://readonly:readonly_pass@localhost:5432/target_db?schema=public"

# AI Provider Configuration
# Set to 'openai' or 'ollama' (defaults to ollama)
AI_PROVIDER="ollama"

# Set the models to use (defaults depend on provider)
# AI_MODEL="llama3" 
# AI_EMBEDDING_MODEL="nomic-embed-text"

# If using OpenAI:
OPENAI_API_KEY="sk-..."

# If using Ollama, defaults to http://127.0.0.1:11434 and llama3
# OLLAMA_HOST="http://127.0.0.1:11434"
